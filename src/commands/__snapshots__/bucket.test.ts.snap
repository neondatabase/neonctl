// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`bucket > object delete 1`] = `""`;

exports[`bucket > object delete reports a helpful error when the object is missing 1`] = `""`;

exports[`bucket > object delete-folder removes every object under the prefix 1`] = `""`;

exports[`bucket > object get downloads to the given file 1`] = `""`;

exports[`bucket > object list 1`] = `
"folders:
