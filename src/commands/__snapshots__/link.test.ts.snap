// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`link > --agent mode > with full project details creates project and emits linked JSON 1`] = `
"{
  "status": "linked",
  "context_file": "<TMP>/agent_linked_create/.neon",
  "context": {
    "orgId": "org-2",
    "projectId": "new-project-789012",
    "branchId": "br-test-branch-789012"
  },
  "project": {
    "id": "new-project-789012",
    "name": "test_project"
  },
  "message": "Created project new-project-789012 (\\"test_project\\") in aws-us-east-2 and linked <TMP>/agent_linked_create/.neon. Next: run \`neonctl env pull\` to write this branch’s env vars (DATABASE_URL, …) into a local .env"
}
"
`;

