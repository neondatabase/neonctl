exports[`describe/queries — pg17 snapshots > describeConfigurationParameters / pg17 1`] = `
{
  "description": "List of non-default configuration parameters",
  "params": [],
  "sql": "SELECT s.name AS "Parameter", pg_catalog.current_setting(s.name) AS "Value"
FROM pg_catalog.pg_settings s
WHERE s.source <> 'default' AND s.setting IS DISTINCT FROM s.boot_val
ORDER BY 1;",
}
`;

exports[`describe/queries — pg17 snapshots > describeFunctions > pg17 / functypes=ap (aggregates+procedures) 1`] = `
{
  "description": "List of functions",
  "params": [],
  "sql": "SELECT n.nspname as "Schema",
  p.proname as "Name",
  pg_catalog.pg_get_function_result(p.oid) as "Result data type",
  pg_catalog.pg_get_function_arguments(p.oid) as "Argument data types",
 CASE p.prokind
  WHEN 'a' THEN 'agg'
  WHEN 'w' THEN 'window'
  WHEN 'p' THEN 'proc'
  ELSE 'func'
 END as "Type"
FROM pg_catalog.pg_proc p
     LEFT JOIN pg_catalog.pg_namespace n ON n.oid = p.pronamespace
WHERE (
       p.prokind = 'a'
       OR p.prokind = 'p'
      )
  AND true /* TODO(WP-20): pattern matching */
      AND n.nspname <> 'pg_catalog'
      AND n.nspname <> 'information_schema'
ORDER BY 1, 2, 4;",
}
`;

