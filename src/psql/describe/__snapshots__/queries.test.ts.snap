// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`describe/queries — pg17 snapshots > describeAccessMethods / pg17 1`] = `
{
  "description": "List of access methods",
  "params": [],
  "sql": "SELECT amname AS "Name",
  CASE amtype WHEN 'i' THEN 'Index' WHEN 't' THEN 'Table' END AS "Type"
FROM pg_catalog.pg_am
WHERE true /* TODO(WP-20): pattern matching */
ORDER BY 1;",
}
`;

exports[`describe/queries — pg17 snapshots > describeAggregates > pg17 / verbose=false 1`] = `
{
  "description": "List of aggregate functions",
  "params": [],
  "sql": "SELECT n.nspname as "Schema",
  p.proname AS "Name",
  pg_catalog.format_type(p.prorettype, NULL) AS "Result data type",
  CASE WHEN p.pronargs = 0
    THEN CAST('*' AS pg_catalog.text)
    ELSE pg_catalog.pg_get_function_arguments(p.oid)
  END AS "Argument data types",
  pg_catalog.obj_description(p.oid, 'pg_proc') as "Description"
FROM pg_catalog.pg_proc p
     LEFT JOIN pg_catalog.pg_namespace n ON n.oid = p.pronamespace
WHERE p.prokind = 'a'
      AND n.nspname <> 'pg_catalog'
      AND n.nspname <> 'information_schema'
  AND true /* TODO(WP-20): pattern matching */
ORDER BY 1, 2, 4;",
}
`;

