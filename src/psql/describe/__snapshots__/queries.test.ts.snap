exports[`describe/queries — pg17 snapshots > listForeignServers / pg17 1`] = `
{
  "description": "List of foreign servers",
  "params": [],
  "sql": "SELECT s.srvname AS "Name",
  pg_catalog.pg_get_userbyid(s.srvowner) AS "Owner",
  f.fdwname AS "Foreign-data wrapper"
FROM pg_catalog.pg_foreign_server s
     JOIN pg_catalog.pg_foreign_data_wrapper f ON f.oid=s.srvfdw
WHERE true /* TODO(WP-20): pattern matching */
ORDER BY 1;",
}
`;

exports[`describe/queries — pg17 snapshots > listForeignTables / pg17 1`] = `
{
  "description": "List of foreign tables",
  "params": [],
  "sql": "SELECT n.nspname AS "Schema",
  c.relname AS "Table",
  s.srvname AS "Server"
FROM pg_catalog.pg_foreign_table ft
  INNER JOIN pg_catalog.pg_class c ON c.oid = ft.ftrelid
  INNER JOIN pg_catalog.pg_namespace n ON n.oid = c.relnamespace
  INNER JOIN pg_catalog.pg_foreign_server s ON s.oid = ft.ftserver
WHERE true /* TODO(WP-20): pattern matching */
ORDER BY 1, 2;",
}
`;

exports[`describe/queries — pg17 snapshots > listLanguages / pg17 1`] = `
{
  "description": "List of languages",
  "params": [],
  "sql": "SELECT l.lanname AS "Name",
       pg_catalog.pg_get_userbyid(l.lanowner) as "Owner",
       l.lanpltrusted AS "Trusted",
       d.description AS "Description"
FROM pg_catalog.pg_language l
LEFT JOIN pg_catalog.pg_description d
  ON d.classoid = l.tableoid AND d.objoid = l.oid AND d.objsubid = 0
WHERE l.lanplcallfoid != 0
ORDER BY 1;",
}
`;

exports[`describe/queries — pg17 snapshots > listLargeObjects / pg17 1`] = `
