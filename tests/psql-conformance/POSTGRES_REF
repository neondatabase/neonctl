# PostgreSQL source-of-truth pin for the psql-conformance harness.
#
# This file is the single source of pinned versions for:
#   - The upstream regression SQL + expected outputs the harness fetches
#     at test bootstrap (see `harness/upstream-fixtures.ts`). No on-disk
#     copy of these files lives in this repo.
#   - The test postgres server image (used by GHA + testcontainers).
#
# To bump the upstream PG pin: change PG_TAG / PG_COMMIT below and
# update PG_IMAGE / PG_IMAGE_DIGEST to a matching docker tag. The next
# `bun run test:conformance` re-fetches against the new tag.

PG_VERSION=18.0
PG_TAG=REL_18_0
PG_COMMIT=3d6a828938a5fa0444275d3d2f67b64ec3199eb7

# Image digest for docker.io/library/postgres:18.0 (used by GHA service
# container and by @testcontainers/postgresql when running locally).
PG_IMAGE=postgres:18.0
PG_IMAGE_DIGEST=sha256:41fc5342eefba6cc2ccda736aaf034bbbb7c3df0fdb81516eba1ba33f360162c
